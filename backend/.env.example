# =============================================================================
# 企业级私有化多模态 RAG 系统 - 后端环境变量示例
# 复制本文件为 backend/.env 并根据实际环境修改
# （根目录 .env.example 为全栈主模板）
# 注意：以下所有密码/密钥仅为示例占位符，生产环境必须替换为强随机值
# =============================================================================

# ------------------------------------------------------------------
# Docker Compose
# ------------------------------------------------------------------
COMPOSE_PROJECT_NAME=rag-system

# ------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_password
POSTGRES_DB=rag_kb
DATABASE_URL=postgresql://rag_user:rag_password@postgres:5432/rag_kb

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------
# RabbitMQ
# ------------------------------------------------------------------
RABBITMQ_DEFAULT_USER=rag_user
RABBITMQ_DEFAULT_PASS=rag_password
RABBITMQ_DEFAULT_VHOST=/
RABBITMQ_URL=amqp://rag_user:rag_password@rabbitmq:5672/

# ------------------------------------------------------------------
# Celery broker
# ------------------------------------------------------------------
# Celery broker: "rabbitmq" or "redis"
CELERY_BROKER_TYPE=rabbitmq
CELERY_TASK_ALWAYS_EAGER=false

# ------------------------------------------------------------------
# MinIO (对象存储)
# 请替换为实际 MinIO 部署的强随机凭据
# ------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-documents

# 文件存储后端："s3" (MinIO/S3) 或 "local" (本地文件系统)
FILE_STORAGE_BACKEND=s3
LOCAL_STORAGE_PATH=/data/rag-documents

# ------------------------------------------------------------------
# Milvus (向量数据库)
# ------------------------------------------------------------------
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_COLLECTION_PREFIX=rag

# ------------------------------------------------------------------
# 安全 / JWT
# 使用 JWT_SECRET_KEY；也支持使用 SECRET_KEY 作为别名（兼容旧配置）
# 生成示例：openssl rand -hex 32
# ------------------------------------------------------------------
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 管理员用户名（逗号分隔），用于用户管理端点的权限校验
ADMIN_USERNAMES=admin

# ------------------------------------------------------------------
# CORS
# 多个来源使用英文逗号分隔，例如：http://localhost:5173,https://app.example.com
# 不配置时默认只允许前端开发地址 http://localhost:5173
# ------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3002,http://localhost:5173

# ------------------------------------------------------------------
# 模型服务（私有化部署时替换为内网地址）
# ------------------------------------------------------------------
EMBEDDING_SERVICE_URL=http://embedding-service:8080/embed
EMBEDDING_MODEL_URL=http://embedding-service:8080/embed
EMBEDDING_API_URL=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=
EMBEDDING_DIMENSION=768

RERANK_SERVICE_URL=http://rerank-service:8080/rerank
RERANK_API_URL=
RERANK_MODEL=bge-reranker-large
RERANK_API_KEY=

LLM_API_URL=https://api.minimax.chat/v1/chat/completions
LLM_MODEL=minimax-m3
LLM_API_KEY=
MINIMAX_API_KEY=sk-xxx
MINIMAX_BASE_URL=https://api.minimax.chat

# ------------------------------------------------------------------
# Grafana
# ------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ------------------------------------------------------------------
# Kong placeholder API key (key-auth plugin)
# 请求 /api/* 时需要在 Header 中携带: apikey: placeholder-api-key
# ------------------------------------------------------------------
KONG_API_KEY=placeholder-api-key

# ------------------------------------------------------------------
# Docker image / mock service placeholders used by docker-compose.yml
# ------------------------------------------------------------------
BACKEND_IMAGE=your-dockerhub-username/rag-backend
FRONTEND_IMAGE=your-dockerhub-username/rag-frontend
IMAGE_TAG=latest
MOCK_LLM_PORT=8080
