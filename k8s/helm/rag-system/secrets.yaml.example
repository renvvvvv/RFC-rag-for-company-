# =============================================================================
# Helm values override for sensitive secrets.
# Copy this file to secrets.yaml and fill in real values before installing.
# NEVER commit secrets.yaml to Git.
# =============================================================================

secrets:
  # PostgreSQL
  POSTGRES_USER: "rag_user"
  POSTGRES_PASSWORD: "change-me-to-strong-password"
  DATABASE_URL: "postgresql://rag_user:change-me-to-strong-password@rag-system-postgres:5432/rag_kb"

  # Redis
  REDIS_URL: "redis://rag-system-redis:6379/0"

  # RabbitMQ
  RABBITMQ_DEFAULT_USER: "rag_user"
  RABBITMQ_DEFAULT_PASS: "change-me-to-strong-password"
  RABBITMQ_URL: "amqp://rag_user:change-me-to-strong-password@rag-system-rabbitmq:5672/"

  # MinIO
  MINIO_ROOT_USER: "minioadmin"
  MINIO_ROOT_PASSWORD: "change-me-to-strong-password"
  MINIO_ACCESS_KEY: "minioadmin"
  MINIO_SECRET_KEY: "change-me-to-strong-password"

  # JWT
  JWT_SECRET_KEY: "change-me-to-strong-secret-key"

  # External model API keys (fill if using cloud providers)
  EMBEDDING_API_URL: ""
  EMBEDDING_API_KEY: ""
  RERANK_API_URL: ""
  RERANK_API_KEY: ""
  LLM_API_URL: ""
  LLM_API_KEY: ""
  MINIMAX_API_KEY: ""

  # Grafana
  GRAFANA_ADMIN_USER: "admin"
  GRAFANA_ADMIN_PASSWORD: "change-me-to-strong-password"
